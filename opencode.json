{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    "node_modules/ecc-universal/skills/tdd-workflow/SKILL.md",
    "node_modules/ecc-universal/skills/security-review/SKILL.md",
    "node_modules/ecc-universal/skills/coding-standards/SKILL.md",
    "node_modules/ecc-universal/skills/backend-patterns/SKILL.md",
    "node_modules/ecc-universal/skills/verification-loop/SKILL.md",
    "node_modules/ecc-universal/skills/api-design/SKILL.md"
  ],
  "agent": {
    "build": {
      "description": "Primary coding agent for FieldVision AI development",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "changed-files": true
      }
    },
    "planner": {
      "description": "Expert planning specialist for complex features and refactoring",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/planner.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "Software architecture specialist for system design and scalability",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/architect.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Expert code review specialist for quality, security, and maintainability",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/code-reviewer.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection and remediation specialist",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/security-reviewer.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true
      }
    },
    "tdd-guide": {
      "description": "Test-Driven Development specialist enforcing write-tests-first methodology",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/tdd-guide.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "build-error-resolver": {
      "description": "Build and type error resolution specialist",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/build-error-resolver.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "python-reviewer": {
      "description": "Expert Python code reviewer for PEP 8, type hints, security, and performance",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/python-reviewer.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "kotlin-reviewer": {
      "description": "Kotlin and Android code reviewer for idiomatic patterns and coroutine safety",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/kotlin-reviewer.md}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "kotlin-build-resolver": {
      "description": "Kotlin/Gradle build and compilation error resolution specialist",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/kotlin-build-resolver.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "refactor-cleaner": {
      "description": "Dead code cleanup and consolidation specialist",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-5",
      "prompt": "{file:node_modules/ecc-universal/agents/refactor-cleaner.md}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan for complex features",
      "template": "{file:node_modules/ecc-universal/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ test coverage",
      "template": "{file:node_modules/ecc-universal/commands/test-coverage.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Review code for quality, security, and maintainability",
      "template": "{file:node_modules/ecc-universal/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Run comprehensive security review",
      "template": "{file:node_modules/ecc-universal/commands/security-scan.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build and type errors with minimal changes",
      "template": "{file:node_modules/ecc-universal/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "refactor-clean": {
      "description": "Remove dead code and consolidate duplicates",
      "template": "{file:node_modules/ecc-universal/commands/refactor-clean.md}\n\n$ARGUMENTS",
      "agent": "refactor-cleaner",
      "subtask": true
    },
    "verify": {
      "description": "Run verification loop",
      "template": "{file:node_modules/ecc-universal/commands/quality-gate.md}\n\n$ARGUMENTS"
    },
    "learn": {
      "description": "Extract patterns and learnings from session",
      "template": "{file:node_modules/ecc-universal/commands/learn.md}\n\n$ARGUMENTS"
    }
  },
  "permission": {
    "mcp_*": "ask"
  }
}
