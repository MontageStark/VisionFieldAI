<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Camera Preview (Full Screen) -->
    <TextureView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Gradient Overlay -->
    <View
        android:id="@+id/topGradient"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:background="@drawable/gradient_top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Gradient Overlay -->
    <View
        android:id="@+id/bottomGradient"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/gradient_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Status Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App Logo/Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FieldVision"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.05" />

        <!-- Live Indicator -->
        <LinearLayout
            android:id="@+id/liveIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_live_indicator"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone"
            tools:visibility="visible">

            <View
                android:id="@+id/liveDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_live_dot"
                android:layout_marginEnd="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="@color/status_streaming"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>

    <!-- Connection Status Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/background_glass"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_status_dot_idle"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready to stream"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Control Panel -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Network Info Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/networkCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/background_glass"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <!-- Network Icon -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/text_hint" />

                <LinearLayout
                    android:id="@+id/networkInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/networkType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Network"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/networkBandwidth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detecting..."
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif" />

                    <TextView
                        android:id="@+id/ipAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IP: --"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Resolution Badge -->
                <TextView
                    android:id="@+id/resolutionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4K"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_resolution_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Resolution Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:weightSum="4">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4K"
                style="@style/ResolutionButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="4K"
                android:textColor="@color/button_text_inactive"
                android:backgroundTint="@color/button_inactive"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1080p"
                style="@style/ResolutionButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1080p"
                android:textColor="@color/button_text_inactive"
                android:backgroundTint="@color/button_inactive"
                android:layout_marginHorizontal="3dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn720p"
                style="@style/ResolutionButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="720p"
                android:textColor="@color/button_text_inactive"
                android:backgroundTint="@color/button_inactive"
                android:layout_marginHorizontal="3dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAuto"
                style="@style/ResolutionButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto"
                android:textColor="@color/button_text_active"
                android:backgroundTint="@color/primary"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Stream Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStream"
            style="@style/StreamButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Streaming"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/primary"
            app:cornerRadius="28dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
